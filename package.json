{
  "name": "beat-parry-rhythm-game",
  "version": "1.0.0",
  "private": true,
  "description": "Beat Parry rhythm game with Neon Postgres user progress",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --test test/**/*.test.js",
    "stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-server.ps1",
    "restart": "npm run stop && npm start",
    "generate-sounds": "node scripts/generate-parry-sounds.js",
    "migrate:sqlite": "node scripts/migrate-sqlite-to-neon.js",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:check": "wrangler check"
  },
  "dependencies": {
    "@neon/config": "^0.9.2",
    "@neon/env": "^0.11.1",
    "express": "^4.21.2",
    "pg": "^8.16.0",
    "postgres-migrations": "^5.3.0"
  },
  "devDependencies": {
    "sql.js": "^1.13.0",
    "supertest": "^7.1.1",
    "wrangler": "^4.111.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.9.0"
  }
}
