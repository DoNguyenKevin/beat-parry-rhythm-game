# Neon Postgres (required)
# Pooled connection for the Express server runtime
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Direct (non-pooler) connection for migrations and one-time imports
# Alias: DATABASE_URL_UNPOOLED (also supported)
DATABASE_URL_DIRECT=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Optional: separate database for integration tests (defaults to DATABASE_URL)
TEST_DATABASE_URL=

# Server port (default 3000)
PORT=3000

# Cloudflare Workers (optional — for `npm run cf:dev` / `npm run cf:deploy`)
# Copy .dev.vars.example to .dev.vars for local wrangler dev.
# In production, set secrets in the dashboard or via:
#   npx wrangler secret put DATABASE_URL
#   npx wrangler secret put DATABASE_URL_DIRECT
